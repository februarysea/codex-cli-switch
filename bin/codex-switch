#!/usr/bin/env bash

set -euo pipefail

SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
SWITCH_HOME="${CODEX_SWITCH_HOME:-$HOME/.codex-profiles}"
DEFAULT_CODEX_HOME="${HOME}/.codex"
SHARED_SKILLS_HOME="${CODEX_SWITCH_SHARED_HOME:-$HOME/.codex-shared}"
SHARED_SKILLS_DIR="${CODEX_SWITCH_SHARED_SKILLS_DIR:-$SHARED_SKILLS_HOME/skills}"
SHARED_RESUME_HOME="${CODEX_SWITCH_SHARED_RESUME_HOME:-$SHARED_SKILLS_HOME/resume}"
SHARED_RESUME_SESSIONS_DIR="${CODEX_SWITCH_SHARED_SESSIONS_DIR:-$SHARED_RESUME_HOME/sessions}"
SHARED_RESUME_ARCHIVED_SESSIONS_DIR="${CODEX_SWITCH_SHARED_ARCHIVED_SESSIONS_DIR:-$SHARED_RESUME_HOME/archived_sessions}"
SHARED_RESUME_INDEX="${CODEX_SWITCH_SHARED_SESSION_INDEX:-$SHARED_RESUME_HOME/session_index.jsonl}"
SHARED_RESUME_ENABLED_MARKER="$SHARED_RESUME_HOME/.enabled"
VERSION="0.3.1"

usage() {
  cat <<'EOF'
Usage:
  codex-switch <profile|default>
  codex-switch login <profile> [codex-login-args...]
  codex-switch switch <profile|default>
  codex-switch list
  codex-switch logout [profile|default]
  codex-switch skills path
  codex-switch skills init
  codex-switch skills sync [profile|default|all]
  codex-switch resume path
  codex-switch resume init
  codex-switch resume update
  codex-switch version
  codex-switch help

Examples:
  codex-switch work
  codex-switch login work
  codex-switch switch work
  codex-switch default
  codex-switch logout default
  codex-switch skills path
  codex-switch skills sync all
  codex-switch resume init
  codex-switch resume update
  printenv OPENAI_API_KEY_WORK | codex-switch login api-work --with-api-key

Compatibility aliases:
  use -> switch
  off -> switch default
EOF
}

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

require_codex() {
  command -v codex >/dev/null 2>&1 || die "codex is not installed or not in PATH"
}

validate_profile_name() {
  local name="${1:-}"
  [[ -n "$name" ]] || die "profile name is required"
  [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] || die "profile name must match [A-Za-z0-9._-]+"
}

is_default_profile() {
  local name="${1:-}"
  [[ "$name" == "default" || "$name" == "-" ]]
}

profile_dir() {
  if is_default_profile "${1:-}"; then
    printf '%s\n' "$DEFAULT_CODEX_HOME"
    return 0
  fi
  validate_profile_name "$1"
  printf '%s/%s\n' "$SWITCH_HOME" "$1"
}

ensure_profile_dir() {
  local dir
  dir="$(profile_dir "$1")"
  mkdir -p "$dir"
  printf '%s\n' "$dir"
}

copy_config_if_present() {
  local dest_dir="$1"
  local source_home="${CODEX_HOME:-$DEFAULT_CODEX_HOME}"
  local source_config="${source_home}/config.toml"
  local dest_config="${dest_dir}/config.toml"

  if [[ -f "$source_config" && ! -f "$dest_config" ]]; then
    cp "$source_config" "$dest_config"
  fi
}

ensure_shared_skills_dir() {
  mkdir -p "$SHARED_SKILLS_DIR"
}

sync_shared_skills_to_home() {
  local home_dir="$1"
  local mode="${2:-quiet}"
  local skills_dir="$home_dir/skills"
  local linked=0
  local skipped=0

  ensure_shared_skills_dir
  mkdir -p "$skills_dir"

  local source
  shopt -s nullglob dotglob
  for source in "$SHARED_SKILLS_DIR"/*; do
    [[ -e "$source" ]] || continue
    local name target
    name="$(basename "$source")"
    target="$skills_dir/$name"

    if [[ -L "$target" ]]; then
      local current_target
      current_target="$(readlink "$target" || true)"
      if [[ "$current_target" == "$source" ]]; then
        continue
      fi
      rm -f "$target"
      ln -s "$source" "$target"
      linked=$((linked + 1))
      continue
    fi

    if [[ -e "$target" ]]; then
      skipped=$((skipped + 1))
      continue
    fi

    ln -s "$source" "$target"
    linked=$((linked + 1))
  done
  shopt -u nullglob dotglob

  if [[ "$mode" == "verbose" ]]; then
    printf 'Synced shared skills into %s (linked=%d, skipped=%d)\n' "$home_dir" "$linked" "$skipped"
  fi
}

sync_shared_skills_to_profile() {
  local profile="${1:-default}"
  local home_dir
  home_dir="$(profile_dir "$profile")"
  mkdir -p "$home_dir"
  sync_shared_skills_to_home "$home_dir" "${2:-quiet}"
}

ensure_shared_resume_dir() {
  mkdir -p "$SHARED_RESUME_SESSIONS_DIR" "$SHARED_RESUME_ARCHIVED_SESSIONS_DIR"
  [[ -e "$SHARED_RESUME_INDEX" ]] || : > "$SHARED_RESUME_INDEX"
}

enable_shared_resume() {
  ensure_shared_resume_dir
  : > "$SHARED_RESUME_ENABLED_MARKER"
}

is_shared_resume_enabled() {
  [[ -f "$SHARED_RESUME_ENABLED_MARKER" ]]
}

copy_resume_tree_to_shared() {
  local source_root="$1"
  local dest_root="$2"

  [[ -e "$source_root" ]] || return 0
  if [[ -L "$source_root" ]]; then
    local current_target
    current_target="$(readlink "$source_root" || true)"
    [[ "$current_target" == "$dest_root" ]] && return 0
  fi

  mkdir -p "$dest_root"
  if cp --help 2>/dev/null | grep -q -- '--update'; then
    cp -a --update=none "$source_root"/. "$dest_root"/
  else
    cp -an "$source_root"/. "$dest_root"/
  fi
}

merge_shared_resume_index() {
  ensure_shared_resume_dir
  SHARED_RESUME_INDEX="$SHARED_RESUME_INDEX" \
  DEFAULT_CODEX_HOME="$DEFAULT_CODEX_HOME" \
  SWITCH_HOME="$SWITCH_HOME" \
  python3 - <<'PY'
import json
import os
from pathlib import Path

shared_index = Path(os.environ["SHARED_RESUME_INDEX"]).expanduser()
default_home = Path(os.environ["DEFAULT_CODEX_HOME"]).expanduser()
switch_home = Path(os.environ["SWITCH_HOME"]).expanduser()

homes = [default_home]
if switch_home.exists():
    homes.extend(child for child in sorted(switch_home.iterdir()) if child.is_dir())

sources = [shared_index]
sources.extend(home / "session_index.jsonl" for home in homes)

records = {}
for source in sources:
    if not source.exists():
        continue
    if source != shared_index:
        try:
            if source.samefile(shared_index):
                continue
        except OSError:
            pass
    try:
        lines = source.read_text(errors="ignore").splitlines()
    except Exception:
        continue
    for line in lines:
        try:
            obj = json.loads(line)
        except Exception:
            continue
        session_id = obj.get("id")
        if not session_id:
            continue
        previous = records.get(session_id)
        if previous is None or str(obj.get("updated_at", "")) >= str(previous.get("updated_at", "")):
            records[session_id] = obj

tmp = shared_index.with_suffix(shared_index.suffix + ".tmp")
with tmp.open("w", encoding="utf-8") as fh:
    for obj in sorted(records.values(), key=lambda item: str(item.get("updated_at", ""))):
        fh.write(json.dumps(obj, ensure_ascii=False, separators=(",", ":")) + "\n")
tmp.replace(shared_index)
PY
}

sync_all_resume_sources_to_shared() {
  ensure_shared_resume_dir

  copy_resume_tree_to_shared "$DEFAULT_CODEX_HOME/sessions" "$SHARED_RESUME_SESSIONS_DIR"
  copy_resume_tree_to_shared "$DEFAULT_CODEX_HOME/archived_sessions" "$SHARED_RESUME_ARCHIVED_SESSIONS_DIR"

  if [[ -d "$SWITCH_HOME" ]]; then
    local dir
    shopt -s nullglob
    for dir in "$SWITCH_HOME"/*; do
      [[ -d "$dir" ]] || continue
      copy_resume_tree_to_shared "$dir/sessions" "$SHARED_RESUME_SESSIONS_DIR"
      copy_resume_tree_to_shared "$dir/archived_sessions" "$SHARED_RESUME_ARCHIVED_SESSIONS_DIR"
    done
    shopt -u nullglob
  fi

  merge_shared_resume_index
}

backup_resume_path() {
  local home_dir="$1"
  local target="$2"
  local name="$3"
  local stamp
  local backup_dir
  stamp="$(date +%Y%m%d-%H%M%S)"
  backup_dir="$home_dir/.codex-switch-backup/$stamp"
  mkdir -p "$backup_dir"
  mv "$target" "$backup_dir/$name"
}

link_shared_resume_path() {
  local home_dir="$1"
  local name="$2"
  local shared_path="$3"
  local target="$home_dir/$name"

  mkdir -p "$home_dir"
  if [[ -L "$target" ]]; then
    local current_target
    current_target="$(readlink "$target" || true)"
    [[ "$current_target" == "$shared_path" ]] && return 0
    backup_resume_path "$home_dir" "$target" "$name"
  elif [[ -e "$target" ]]; then
    backup_resume_path "$home_dir" "$target" "$name"
  fi

  ln -s "$shared_path" "$target"
}

link_shared_resume_to_home() {
  local home_dir="$1"
  link_shared_resume_path "$home_dir" "sessions" "$SHARED_RESUME_SESSIONS_DIR"
  link_shared_resume_path "$home_dir" "archived_sessions" "$SHARED_RESUME_ARCHIVED_SESSIONS_DIR"
  link_shared_resume_path "$home_dir" "session_index.jsonl" "$SHARED_RESUME_INDEX"
}

merge_resume_state_to_home() {
  local target_home="$1"

  TARGET_HOME="$target_home" \
  DEFAULT_CODEX_HOME="$DEFAULT_CODEX_HOME" \
  SWITCH_HOME="$SWITCH_HOME" \
  python3 - <<'PY'
import os
import sqlite3
from pathlib import Path

target_home = Path(os.environ["TARGET_HOME"]).expanduser()
default_home = Path(os.environ["DEFAULT_CODEX_HOME"]).expanduser()
switch_home = Path(os.environ["SWITCH_HOME"]).expanduser()
target_db = target_home / "state_5.sqlite"
thread_tables = [
    "threads",
    "stage1_outputs",
    "thread_dynamic_tools",
    "thread_goals",
    "thread_spawn_edges",
]

homes = [default_home]
if switch_home.exists():
    homes.extend(child for child in sorted(switch_home.iterdir()) if child.is_dir())

source_dbs = []
seen = set()
for home in homes:
    db = home / "state_5.sqlite"
    if not db.exists():
        continue
    try:
        key = db.resolve()
    except OSError:
        key = db
    if key in seen:
        continue
    seen.add(key)
    source_dbs.append(db)

if not source_dbs:
    raise SystemExit(0)

def connect_readonly(path: Path):
    return sqlite3.connect(f"file:{path}?mode=ro", uri=True)

def table_names(con):
    return {
        row[0]
        for row in con.execute("select name from sqlite_master where type='table'")
    }

def table_columns(con, table):
    return [row[1] for row in con.execute(f"pragma table_info({table})")]

def placeholders(count):
    return ",".join("?" for _ in range(count))

def quote_ident(name):
    return '"' + name.replace('"', '""') + '"'

def ensure_target_schema():
    if target_db.exists():
        return
    target_home.mkdir(parents=True, exist_ok=True)
    with connect_readonly(source_dbs[0]) as src, sqlite3.connect(target_db) as dst:
        rows = src.execute(
            """
            select type, name, sql
            from sqlite_master
            where sql is not null
              and name not like 'sqlite_%'
            order by case type
                when 'table' then 0
                when 'index' then 1
                when 'trigger' then 2
                when 'view' then 3
                else 4
            end, name
            """
        ).fetchall()
        for _, _, sql in rows:
            try:
                dst.execute(sql)
            except sqlite3.OperationalError:
                pass
        if "_sqlx_migrations" in table_names(src) and "_sqlx_migrations" in table_names(dst):
            cols = table_columns(src, "_sqlx_migrations")
            col_sql = ",".join(quote_ident(col) for col in cols)
            for row in src.execute(f"select {col_sql} from _sqlx_migrations"):
                dst.execute(
                    f"insert or ignore into _sqlx_migrations ({col_sql}) values ({placeholders(len(cols))})",
                    row,
                )

def row_timestamp(cols, row):
    for name in ("updated_at_ms", "updated_at"):
        if name in cols:
            value = row[cols.index(name)]
            if value is not None:
                return int(value)
    return 0

ensure_target_schema()

with sqlite3.connect(target_db) as dst:
    dst.execute("pragma foreign_keys=off")
    dst_tables = table_names(dst)
    for source_db in source_dbs:
        try:
            if source_db.resolve() == target_db.resolve():
                continue
        except OSError:
            if source_db == target_db:
                continue
        with connect_readonly(source_db) as src:
            src_tables = table_names(src)
            for table in thread_tables:
                if table not in src_tables or table not in dst_tables:
                    continue
                src_cols = table_columns(src, table)
                dst_cols = table_columns(dst, table)
                common_cols = [col for col in src_cols if col in dst_cols]
                if not common_cols:
                    continue
                col_sql = ",".join(quote_ident(col) for col in common_cols)
                select_sql = f"select {col_sql} from {quote_ident(table)}"
                insert_sql = (
                    f"insert or replace into {quote_ident(table)} ({col_sql}) "
                    f"values ({placeholders(len(common_cols))})"
                )
                if table == "threads":
                    id_index = common_cols.index("id")
                    for row in src.execute(select_sql):
                        thread_id = row[id_index]
                        existing = dst.execute(
                            "select updated_at_ms, updated_at from threads where id = ?",
                            (thread_id,),
                        ).fetchone()
                        if existing is not None:
                            existing_ts = existing[0] if existing[0] is not None else existing[1]
                            if int(existing_ts or 0) > row_timestamp(common_cols, row):
                                continue
                        dst.execute(insert_sql, row)
                else:
                    for row in src.execute(select_sql):
                        dst.execute(insert_sql, row)
    dst.commit()
PY
}

sync_shared_resume_to_home() {
  local home_dir="$1"
  local mode="${2:-quiet}"

  sync_all_resume_sources_to_shared
  link_shared_resume_to_home "$home_dir"
  merge_resume_state_to_home "$home_dir"

  if [[ "$mode" == "verbose" ]]; then
    printf 'Synced shared resume into %s\n' "$home_dir"
  fi
}

sync_shared_resume_to_profile() {
  local profile="${1:-default}"
  local home_dir
  home_dir="$(profile_dir "$profile")"
  mkdir -p "$home_dir"
  sync_shared_resume_to_home "$home_dir" "${2:-quiet}"
}

sync_shared_resume_current_if_enabled() {
  is_shared_resume_enabled || return 0

  local current_home="${CODEX_HOME:-$DEFAULT_CODEX_HOME}"
  [[ -d "$current_home" ]] || return 0
  sync_shared_resume_to_home "$current_home" quiet
}

sync_shared_resume_to_profile_if_enabled() {
  is_shared_resume_enabled || return 0
  sync_shared_resume_to_profile "$1" quiet
}

cmd_login() {
  local profile="${1:-}"
  shift || true

  require_codex

  local dir
  if is_default_profile "$profile"; then
    dir="$DEFAULT_CODEX_HOME"
    mkdir -p "$dir"
  else
    validate_profile_name "$profile"
    dir="$(ensure_profile_dir "$profile")"
    copy_config_if_present "$dir"
  fi

  sync_shared_skills_to_home "$dir" quiet

  CODEX_HOME="$dir" CODEX_PROFILE="$profile" codex login "$@"
  if is_shared_resume_enabled; then
    sync_shared_resume_to_home "$dir" quiet
  fi
}

cmd_logout() {
  local profile="${1:-default}"

  require_codex

  local dir
  if is_default_profile "$profile"; then
    dir="$DEFAULT_CODEX_HOME"
    mkdir -p "$dir"
    CODEX_HOME="$dir" codex logout
  else
    validate_profile_name "$profile"
    dir="$(profile_dir "$profile")"
    [[ -d "$dir" ]] || die "profile '$profile' does not exist"
    CODEX_HOME="$dir" CODEX_PROFILE="$profile" codex logout
  fi
}

cmd_run() {
  local profile="${1:-}"
  shift || true

  validate_profile_name "$profile"
  require_codex

  if (($#)) && [[ "$1" == "--" ]]; then
    shift
  fi

  local dir
  dir="$(profile_dir "$profile")"
  [[ -d "$dir" ]] || die "profile '$profile' does not exist; run 'codex-switch create $profile' first"

  sync_shared_resume_current_if_enabled
  sync_shared_resume_to_profile_if_enabled "$profile"

  CODEX_HOME="$dir" CODEX_PROFILE="$profile" codex "$@"
}

shell_quote() {
  printf "%q" "$1"
}

cmd_switch() {
  local profile="${1:-}"

  if is_default_profile "$profile"; then
    sync_shared_resume_current_if_enabled
    sync_shared_resume_to_profile_if_enabled default
    cat <<'EOF'
unset CODEX_HOME
unset CODEX_PROFILE
EOF
    return 0
  fi

  validate_profile_name "$profile"

  local dir
  dir="$(profile_dir "$profile")"
  [[ -d "$dir" ]] || die "profile '$profile' does not exist"
  sync_shared_resume_current_if_enabled
  sync_shared_skills_to_home "$dir" quiet
  sync_shared_resume_to_profile_if_enabled "$profile"

  printf 'export CODEX_HOME=%s\n' "$(shell_quote "$dir")"
  printf 'export CODEX_PROFILE=%s\n' "$(shell_quote "$profile")"
}

cmd_skills() {
  local subcommand="${1:-path}"
  shift || true

  case "$subcommand" in
    path)
      ensure_shared_skills_dir
      printf '%s\n' "$SHARED_SKILLS_DIR"
      ;;
    init)
      ensure_shared_skills_dir
      sync_shared_skills_to_profile default verbose
      if [[ -d "$SWITCH_HOME" ]]; then
        local dir
        shopt -s nullglob
        for dir in "$SWITCH_HOME"/*; do
          [[ -d "$dir" ]] || continue
          sync_shared_skills_to_home "$dir" verbose
        done
        shopt -u nullglob
      fi
      printf 'Shared skills root: %s\n' "$SHARED_SKILLS_DIR"
      ;;
    sync)
      local target="${1:-all}"
      if [[ "$target" == "all" ]]; then
        sync_shared_skills_to_profile default verbose
        if [[ -d "$SWITCH_HOME" ]]; then
          local dir
          shopt -s nullglob
          for dir in "$SWITCH_HOME"/*; do
            [[ -d "$dir" ]] || continue
            sync_shared_skills_to_home "$dir" verbose
          done
          shopt -u nullglob
        fi
      else
        sync_shared_skills_to_profile "$target" verbose
      fi
      ;;
    *)
      die "unknown skills command: $subcommand"
      ;;
  esac
}

cmd_resume() {
  local subcommand="${1:-path}"
  shift || true

  case "$subcommand" in
    path)
      ensure_shared_resume_dir
      printf '%s\n' "$SHARED_RESUME_HOME"
      ;;
    init)
      enable_shared_resume
      sync_shared_resume_to_profile default verbose
      if [[ -d "$SWITCH_HOME" ]]; then
        local dir
        shopt -s nullglob
        for dir in "$SWITCH_HOME"/*; do
          [[ -d "$dir" ]] || continue
          sync_shared_resume_to_home "$dir" verbose
        done
        shopt -u nullglob
      fi
      printf 'Shared resume root: %s\n' "$SHARED_RESUME_HOME"
      ;;
    update)
      enable_shared_resume
      sync_shared_resume_to_profile default verbose
      if [[ -d "$SWITCH_HOME" ]]; then
        local dir
        shopt -s nullglob
        for dir in "$SWITCH_HOME"/*; do
          [[ -d "$dir" ]] || continue
          sync_shared_resume_to_home "$dir" verbose
        done
        shopt -u nullglob
      fi
      printf 'Shared resume root: %s\n' "$SHARED_RESUME_HOME"
      ;;
    *)
      die "unknown resume command: $subcommand"
      ;;
  esac
}

known_command() {
  case "${1:-}" in
    login|switch|use|activate|list|logout|skills|resume|run|exec|off|deactivate|shell-init|init-shell|version|--version|-V|help|-h|--help)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

cmd_switch_hint() {
  local profile="${1:-}"
  cat <<EOF
This command needs shell integration to switch the current shell.

Use one of these:
  eval "\$(codex-switch switch $profile)"
  source ~/.zshrc

If you installed with install.sh and reloaded your shell, plain:
  codex-switch $profile
will switch directly.
EOF
}

cmd_list() {
  mkdir -p "$SWITCH_HOME"
  CURRENT_CODEX_HOME="${CODEX_HOME:-}" \
  CURRENT_CODEX_PROFILE="${CODEX_PROFILE:-default}" \
  DEFAULT_CODEX_HOME="$DEFAULT_CODEX_HOME" \
  SWITCH_HOME="$SWITCH_HOME" \
  CODEX_SWITCH_VERSION="$VERSION" \
  python3 - <<'PY'
import datetime as dt
import json
import os
import re
import shutil
import sqlite3
import subprocess
import textwrap
from pathlib import Path

current_home = os.environ.get("CURRENT_CODEX_HOME", "")
current_profile = os.environ.get("CURRENT_CODEX_PROFILE", "default")
default_home = Path(os.environ["DEFAULT_CODEX_HOME"]).expanduser()
switch_home = Path(os.environ["SWITCH_HOME"]).expanduser()
codex_bin = shutil.which("codex")


def fmt_percent(value):
    if value in (None, "", "-"):
        return "-"
    return f"{value:.0f}%"


def fmt_remaining_percent(value):
    if value in (None, "", "-"):
        return "-"
    try:
        remaining = max(0.0, 100.0 - float(value))
    except (TypeError, ValueError):
        return "-"
    return f"{remaining:.0f}%"


def fmt_reset_short(ts):
    if not ts:
        return "-"
    return dt.datetime.fromtimestamp(ts, dt.timezone.utc).astimezone().strftime("%H:%M")


def fmt_reset_long(ts):
    if not ts:
        return "-"
    return dt.datetime.fromtimestamp(ts, dt.timezone.utc).astimezone().strftime("%m-%d %H:%M")


def empty_usage():
    return {"primary": "-", "secondary": "-", "primary_reset": "-", "secondary_reset": "-", "plan": "-"}


def parse_limit_reset(message):
    if not isinstance(message, str):
        return "-"
    match = re.search(r"try again at\s+(\d{1,2}):(\d{2})\s*([ap]\.?m\.?)", message, re.IGNORECASE)
    if not match:
        return "-"
    hour = int(match.group(1))
    minute = int(match.group(2))
    suffix = match.group(3).lower()
    if suffix.startswith("p") and hour != 12:
        hour += 12
    if suffix.startswith("a") and hour == 12:
        hour = 0
    return f"{hour:02d}:{minute:02d}"


def usage_from_rate_limits(rate):
    if not isinstance(rate, dict):
        return None
    primary = rate.get("primary")
    secondary = rate.get("secondary")
    primary = primary if isinstance(primary, dict) else {}
    secondary = secondary if isinstance(secondary, dict) else {}
    if not primary and not secondary:
        return None
    return {
        "primary": fmt_remaining_percent(primary.get("used_percent")),
        "secondary": fmt_remaining_percent(secondary.get("used_percent")),
        "primary_reset": fmt_reset_short(primary.get("resets_at")),
        "secondary_reset": fmt_reset_long(secondary.get("resets_at")),
        "plan": rate.get("plan_type") or "-",
    }


def read_auth(home: Path):
    auth = home / "auth.json"
    if not auth.exists():
        return {"logged_in": "no", "mode": "-", "account": "-", "has_auth": False}
    try:
        obj = json.loads(auth.read_text())
    except Exception:
        return {"logged_in": "yes", "mode": "(unreadable)", "account": "-", "has_auth": True}
    tokens = obj.get("tokens") if isinstance(obj.get("tokens"), dict) else {}
    account = tokens.get("account_id") if isinstance(tokens, dict) else None
    if isinstance(account, str) and len(account) > 12:
        account = f"{account[:6]}...{account[-4:]}"
    return {
        "logged_in": "yes",
        "mode": obj.get("auth_mode", "-"),
        "account": account or "-",
        "has_auth": True,
    }


def read_login_status(home: Path, profile: str):
    if not codex_bin or not home.exists():
        return None

    env = os.environ.copy()
    env["CODEX_HOME"] = str(home)
    if profile == "default":
        env.pop("CODEX_PROFILE", None)
    else:
        env["CODEX_PROFILE"] = profile

    try:
        result = subprocess.run(
            [codex_bin, "login", "status"],
            env=env,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=5,
            check=False,
        )
    except Exception:
        return None

    output = "\n".join(part.strip() for part in (result.stdout, result.stderr) if part.strip())
    lowered = output.lower()
    if "not logged in" in lowered:
        return {"logged_in": "no", "mode": "-", "account": "-", "has_auth": False}

    match = re.search(r"logged in using\s+(.+)", output, re.IGNORECASE)
    if result.returncode == 0 and match:
        return {"logged_in": "yes", "mode": match.group(1).strip(), "has_auth": True}

    return None


def apply_login_status(auth, status):
    if not status:
        return auth
    if status["logged_in"] == "no":
        return {
            "logged_in": "no",
            "mode": "-",
            "account": "-",
            "has_auth": auth["has_auth"],
        }
    return {
        "logged_in": "yes",
        "mode": status.get("mode") or auth["mode"],
        "account": auth["account"],
        "has_auth": True,
    }


def read_usage(home: Path):
    files = []
    state_db = home / "state_5.sqlite"
    if state_db.exists():
        home_prefix = str(home) + os.sep
        try:
            con = sqlite3.connect(f"file:{state_db}?mode=ro", uri=True)
            rows = con.execute("select rollout_path from threads order by updated_at desc").fetchall()
            con.close()
            for (rollout_path,) in rows:
                if not isinstance(rollout_path, str) or not rollout_path.startswith(home_prefix):
                    continue
                path = Path(rollout_path)
                if path.is_file():
                    files.append(path)
        except Exception:
            files = []
    if not files:
        roots = [home / "sessions", home / "archived_sessions"]
        for root in roots:
            if root.exists():
                files.extend(p for p in root.rglob("*.jsonl") if p.is_file())
    files.sort(key=lambda p: p.stat().st_mtime, reverse=True)

    limit_reset = "-"
    for path in files:
        try:
            lines = path.read_text(errors="ignore").splitlines()
        except Exception:
            continue
        for line in reversed(lines):
            try:
                obj = json.loads(line)
            except Exception:
                continue
            payload = obj.get("payload", {})
            if not isinstance(payload, dict):
                continue
            if obj.get("type") != "event_msg":
                continue
            if payload.get("type") == "error" and payload.get("codex_error_info") == "usage_limit_exceeded":
                limit_reset = parse_limit_reset(payload.get("message"))
                continue
            if payload.get("type") != "token_count":
                continue
            usage = usage_from_rate_limits(payload.get("rate_limits"))
            if usage:
                return usage
    if limit_reset != "-":
        return {"primary": "0%", "secondary": "-", "primary_reset": limit_reset, "secondary_reset": "-", "plan": "-"}
    return empty_usage()


def has_usage(usage):
    return any(usage.get(key) != "-" for key in ("primary", "secondary", "primary_reset", "secondary_reset", "plan"))


rows = []
homes = [("default", default_home)]
if switch_home.exists():
    for child in sorted(switch_home.iterdir()):
        if child.is_dir():
            homes.append((child.name, child))

for name, home in homes:
    status = read_login_status(home, name)
    auth = read_auth(home)
    auth = apply_login_status(auth, status)
    usage = read_usage(home)
    if str(home) == current_home or (name == "default" and not current_home):
      current = "*"
    else:
      current = " "
    if name == "default" and not auth["has_auth"] and not has_usage(usage) and current != "*":
      continue
    rows.append({
        "current": current,
        "profile": name,
        "logged_in": auth["logged_in"],
        "mode": auth["mode"],
        "account": auth["account"],
        "primary": usage["primary"],
        "secondary": usage["secondary"],
        "primary_reset": usage["primary_reset"],
        "secondary_reset": usage["secondary_reset"],
        "plan": usage["plan"],
    })

if not rows:
    print("No Codex profiles found.")
    raise SystemExit(0)

default_row = next((r for r in rows if r["profile"] == "default"), None)
if default_row and default_row["account"] not in ("-", ""):
    for row in rows:
        if row["profile"] == "default":
            continue
        if row["account"] == default_row["account"]:
            merged_profile = f"{row['profile']}(default)"
            replacement = default_row.copy() if default_row["current"] == "*" else row
            replacement["profile"] = merged_profile
            if default_row["current"] == "*":
                replacement["current"] = "*"
            rows = [
                replacement if r is row else r
                for r in rows
                if r is not default_row
            ]
            break


def border(fill="-"):
    return "+" + "+".join(fill * (widths[label] + 2) for label, _ in columns) + "+"


def row(values):
    return "|" + "|".join(f" {str(value):<{widths[label]}} " for (label, _), value in zip(columns, values)) + "|"


def fit_text(text, width):
    text = str(text)
    if len(text) <= width:
        return text
    if width <= 3:
        return text[:width]
    return text[: width - 3] + "..."


def compact_row(row_data):
    return {
        "current": row_data["current"],
        "profile": fit_text(row_data["profile"], 17),
        "logged_in": "yes" if row_data["logged_in"] == "yes" else "no",
        "account": fit_text(row_data["account"], 13),
        "primary": row_data["primary"],
        "secondary": row_data["secondary"],
        "primary_reset": row_data["primary_reset"],
        "secondary_reset": row_data["secondary_reset"],
        "plan": fit_text(row_data["plan"], 4),
    }


rows = [compact_row(r) for r in rows]
columns = [
    ("C", "current"),
    ("Profile", "profile"),
    ("Auth", "logged_in"),
    ("Account", "account"),
    ("5h", "primary"),
    ("R5", "primary_reset"),
    ("7d", "secondary"),
    ("R7", "secondary_reset"),
    ("Plan", "plan"),
]
widths = {
    label: max(len(label), *(len(str(r[key])) for r in rows))
    for label, key in columns
}
table_width = len(border())
now_label = dt.datetime.now().strftime("%Y-%m-%d %H:%M")
title_left = "Codex Switch"
title_right = f"v{os.environ.get('CODEX_SWITCH_VERSION', '0.1.0')}"
summary_left = f"Profiles {len(rows)}"
summary_right = now_label
active_profile = current_profile or next((r["profile"] for r in rows if r["current"] == "*"), "default")
status_left = f"Current {active_profile}"
status_right = "Usage reminder"
inner_width = table_width - 4
use_color = os.isatty(1) and not os.environ.get("NO_COLOR")
current_row_color = "\033[1;36m" if use_color else ""
header_color = "\033[1m" if use_color else ""
muted_color = "\033[2m" if use_color else ""
reset_color = "\033[0m" if use_color else ""


def title_line(left, right):
    left = fit_text(left, inner_width)
    right = fit_text(right, inner_width)
    gap = inner_width - len(left) - len(right)
    if gap < 1:
        left = fit_text(left, inner_width - len(right) - 1)
        gap = 1
    return f"| {left}{' ' * gap}{right} |"


def colorize(line, color):
    if not color:
        return line
    return f"{color}{line}{reset_color}"


print("+" + "-" * (table_width - 2) + "+")
print(colorize(title_line(title_left, title_right), header_color))
print(colorize(title_line(summary_left, summary_right), muted_color))
print(colorize(title_line(status_left, status_right), muted_color))
print(border("="))
print(colorize(row([label for label, _ in columns]), header_color))
print(border("-"))
for r in rows:
    line = row(
        [
            r["current"],
            r["profile"],
            r["logged_in"],
            r["account"],
            r["primary"],
            r["primary_reset"],
            r["secondary"],
            r["secondary_reset"],
            r["plan"],
        ]
    )
    if r["current"] == "*":
        print(colorize(line, current_row_color))
    else:
        print(line)
print(border("-"))
notes = "Notes: C='*' marks current shell profile. 5h/7d show remaining quota. R5 is 5h reset time. R7 is 7d reset date+time."
for line in textwrap.wrap(notes, width=inner_width) or [""]:
    print(colorize(f"| {line:<{inner_width}} |", muted_color))
print("+" + "-" * (table_width - 2) + "+")
PY
}

cmd_shell_init() {
  local shell_name="${1:-zsh}"
  case "$shell_name" in
    zsh|bash)
      ;;
    *)
      die "init-shell only supports zsh or bash"
      ;;
  esac

  cat <<EOF
codex_switch_profile() {
  local profile="\$1"
  if [[ -z "\$profile" ]]; then
    echo "usage: codex_switch_profile <profile|default>" >&2
    return 1
  fi
  eval "\$("$SCRIPT_PATH" switch "\$profile")"
}

codex_use() {
  codex_switch_profile "\$@"
}
EOF
}

cmd_version() {
  printf '%s\n' "$VERSION"
}

main() {
  local command="${1:-help}"
  shift || true

  if ! known_command "$command"; then
    validate_profile_name "$command"
    cmd_switch_hint "$command"
    exit 2
  fi

  case "$command" in
    login)
      cmd_login "$@"
      ;;
    switch|use|activate)
      cmd_switch "$@"
      ;;
    list)
      cmd_list
      ;;
    logout)
      cmd_logout "$@"
      ;;
    skills)
      cmd_skills "$@"
      ;;
    resume)
      cmd_resume "$@"
      ;;
    run|exec)
      cmd_run "$@"
      ;;
    off|deactivate)
      cmd_switch default
      ;;
    shell-init|init-shell)
      cmd_shell_init "$@"
      ;;
    version|--version|-V)
      cmd_version
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      die "unknown command: $command"
      ;;
  esac
}

main "$@"
